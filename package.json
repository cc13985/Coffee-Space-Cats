    "vscode": "^1.0.0"
  },
  "galleryBanner": {
    "color": "#202225",
    "theme": "dark"
  },
  "keywords": [
    "dark",
    "light",
    "space",
    "cats",
    "pink",
    "purple",
    "neon",
    "coffee",
    "aesthetic"
  ],
  "categories": [
