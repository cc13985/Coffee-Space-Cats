        "path": "./themes/Cosmic-Latte-color-theme.json"
      },
      {
        "label": "Coffee Space Cats - Nebula",
        "uiTheme": "vs-dark",
        "path": "./themes/Nebula-color-theme.json"
      },
      {
        "label": "Coffee Space Cats - Midnight",
        "uiTheme": "vs-dark",
        "path": "./themes/Midnight-color-theme.json"
      },
      {
        "label": "Coffee Space Cats - Aurora",
        "uiTheme": "vs-dark",
