  "description": "A space-themed dark and light color theme with neon pink, purple, and cyan accents. Includes 6 variants (dark, light, Cosmic Latte, Nebula, Midnight, Aurora), a matching file icon theme, and full syntax support for 12+ languages.",
  "icon": "img/icon.png",
  "publisher": "CatsCoffee",
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/cc13985/Coffee-Space-Cats"
  },
  "version": "3.2.0",
